def validate_archive(path, strict=True, return_details=False):
    """
    Validate the integrity of a VizFold trace archive.

    This function checks whether the expected archive structure
    exists and whether key datasets appear to be valid.

    Validation behavior:
    --------------------
    strict=True:
        - Enforces presence of core components for a complete archive
        - Treats missing core groups as errors

    strict=False:
        - Supports incremental/partial archives
        - Missing non-essential components are reported as warnings
        - Validates only components currently present

    The goal is to ensure the archive can be safely used for
    offline visualization and analysis.

    Parameters
    ----------
    path : str
        Root path to the Zarr archive.

    strict : bool, optional
        Whether to enforce complete-archive requirements. Default is True.

    return_details : bool, optional
        If True, return a dictionary with validity, warnings, and errors.
        If False, return only a boolean.

    Returns
    -------
    bool | dict
        Boolean validity, or a detailed validation result when
        return_details=True.
    """
    result = {
        "valid": True,
        "warnings": [],
        "errors": [],
    }

    def _fail(message):
        result["valid"] = False
        result["errors"].append(message)

    def _warn(message):
        result["warnings"].append(message)

    try:
        root = zarr.open(path, mode='r')
    except Exception as exc:
        _fail(f"Could not open archive: {exc}")
        return result if return_details else False

    has_structure = False
    has_representations = False
    has_attention = False

    if "layers" in root:
        layers_group = root["layers"]
        for layer_key in layers_group:
            layer = layers_group[layer_key]

            if "activation" not in layer and "attention" not in layer:
                _fail(f"layers/{layer_key} has neither 'activation' nor 'attention'")
                continue

            if "activation" in layer:
                activation = layer["activation"]
                if activation.ndim != 2:
                    _fail(f"layers/{layer_key}/activation must be 2D")
                else:
                    has_representations = True

            if "attention" in layer:
                attention = layer["attention"]
                if attention.ndim != 3:
                    _fail(f"layers/{layer_key}/attention must be 3D")
                else:
                    _, tokens_i, tokens_j = attention.shape
                    if tokens_i != tokens_j:
                        _fail(f"layers/{layer_key}/attention must be square in last two dims")
                    else:
                        has_attention = True

    if "representations" in root:
        representations_group = root["representations"]

        if "single" in representations_group:
            single = representations_group["single"]
            if isinstance(single, zarr.Array):
                has_representations = True
            else:
                for key in single.keys():
                    arr = single[key]
                    if getattr(arr, "ndim", None) is None:
                        continue
                    has_representations = True

        if "pair" in representations_group:
            pair = representations_group["pair"]
            if isinstance(pair, zarr.Array):
                if pair.ndim != 3:
                    _fail("representations/pair must be 3D")
                elif pair.shape[0] != pair.shape[1]:
                    _fail("representations/pair must be square in first two dims")
                else:
                    has_representations = True
            else:
                for key in pair.keys():
                    arr = pair[key]
                    if getattr(arr, "ndim", None) != 3:
                        _fail(f"representations/pair/{key} must be 3D")
                        continue
                    if arr.shape[0] != arr.shape[1]:
                        _fail(f"representations/pair/{key} must be square in first two dims")
                        continue
                    has_representations = True

    if "attention" in root:
        attention_group = root["attention"]
        for attn_type in attention_group.keys():
            type_group = attention_group[attn_type]
            for key in type_group.keys():
                arr = type_group[key]
                if getattr(arr, "ndim", None) != 3:
                    _fail(f"attention/{attn_type}/{key} must be 3D")
                    continue
                if arr.shape[1] != arr.shape[2]:
                    _fail(f"attention/{attn_type}/{key} must be square in last two dims")
                    continue
                has_attention = True

    if "structure" in root:
        structure_group = root["structure"]

        coordinate_key = None
        if "coordinates" in structure_group:
            coordinate_key = "coordinates"
        elif "atom_positions" in structure_group:
            coordinate_key = "atom_positions"

        if coordinate_key is not None:
            coordinates = structure_group[coordinate_key]
            if coordinates.ndim != 2:
                _fail(f"structure/{coordinate_key} must be 2D")
            elif coordinates.shape[-1] != 3:
                _fail(f"structure/{coordinate_key} last dimension must be 3")
            else:
                has_structure = True

                if "residue_types" in structure_group:
                    residue_types = structure_group["residue_types"]
                    if len(residue_types) != coordinates.shape[0]:
                        _fail("structure/residue_types length must match structure coordinates")

                if "atom_mask" in structure_group:
                    atom_mask = structure_group["atom_mask"]
                    if len(atom_mask) != coordinates.shape[0]:
                        _fail("structure/atom_mask length must match structure coordinates")

        elif strict:
            _fail("structure must contain 'coordinates' or 'atom_positions'")
        else:
            _warn("structure is present but missing 'coordinates'/'atom_positions'")
    elif strict:
        _fail("Missing required group: structure")
    else:
        _warn("Missing group: structure")

    if "metadata" not in root:
        if strict:
            _fail("Missing required group: metadata")
        else:
            _warn("Missing group: metadata (allowed for incremental archives)")

    if not has_attention:
        if strict:
            _fail("No valid attention datasets found")
        else:
            _warn("No attention datasets found (allowed for incremental archives)")

    if not has_representations:
        if strict:
            _fail("No valid representation datasets found")
        else:
            _warn("No representation datasets found (allowed for incremental archives)")

    if not has_structure and not has_representations and not has_attention:
        _fail("Archive contains no valid core data components")

    return result if return_details else result["valid"]


def ingest_attention_txt(archive_path, txt_file, layer_index, num_tokens, 
                         attention_type="pairwise", overwrite=False):
    """
    Parse a VizFold attention text file and store it under attention/{attention_type}/layer_{layer_index:02d}.

    Expected input format:
        Layer <idx>, Head <idx>
        <res_i> <res_j> <score>
        ...

    Parameters
    ----------
    archive_path : str
        Root path to the Zarr archive.

    txt_file : str
        Path to the attention text file.

    layer_index : int
        Transformer layer index.

    num_tokens : int
        Number of tokens/residues in the sequence.

    attention_type : str, optional
        Type of attention (e.g., "triangle_start", "triangle_end", "pairwise").
        Default is "pairwise".

    overwrite : bool, optional
        Whether to overwrite existing data. Default is False.

    Returns
    -------
    dict
        Summary of ingestion including layer_index, num_heads, num_tokens, and source_file.
    """
    if num_tokens <= 0:
        raise ValueError("num_tokens must be a positive integer")

    header_pattern = re.compile(r"^Layer\s+(\d+),\s+Head\s+(\d+)$", re.IGNORECASE)
    heads = {}
    current_head = None

    with open(txt_file, "r") as f:
        for raw_line in f:
            line = raw_line.strip()
            if not line:
                continue

            header_match = header_pattern.match(line)
            if header_match:
                file_layer_idx = int(header_match.group(1))
                if file_layer_idx != layer_index:
                    raise ValueError(
                        f"Layer mismatch: function arg layer_index={layer_index}, "
                        f"file header layer={file_layer_idx}"
                    )
                current_head = int(header_match.group(2))
                heads.setdefault(current_head, [])
                continue

            if current_head is None:
                raise ValueError("Found attention row before any layer/head header")

            parts = line.split()
            if len(parts) != 3:
                raise ValueError(f"Malformed attention row: '{line}'")

            res_i = int(float(parts[0]))
            res_j = int(float(parts[1]))
            score = float(parts[2])

            if not (0 <= res_i < num_tokens and 0 <= res_j < num_tokens):
                raise ValueError(
                    f"Residue index out of bounds for num_tokens={num_tokens}: "
                    f"({res_i}, {res_j})"
                )

            heads[current_head].append((res_i, res_j, score))

    if not heads:
        raise ValueError(f"No attention data found in '{txt_file}'")

    num_heads = max(heads.keys()) + 1
    attention = np.zeros((num_heads, num_tokens, num_tokens), dtype=np.float32)

    for head_idx, entries in heads.items():
        for res_i, res_j, score in entries:
            attention[head_idx, res_i, res_j] = score

    store_attention(archive_path, attention_type, layer_index, attention, overwrite=overwrite)
    return {
        "layer_index": layer_index,
        "attention_type": attention_type,
        "num_heads": num_heads,
        "num_tokens": num_tokens,
        "source_file": txt_file,
    }


def _extract_best_matching_array(container, key_token_patterns):
    """
    Find the best array-like match in a nested container using tokenized key patterns.

    Matching is stricter than raw substring search:
    - Key paths are tokenized on non-alphanumeric boundaries.
    - A pattern matches only if all pattern tokens are present in the path tokens.
    - The best match prefers more specific patterns and shorter paths.

    Parameters
    ----------
    container : dict | list | tuple
        Nested object to search.

    key_token_patterns : list[list[str]]
        Ordered token patterns to match (e.g., [["final", "atom", "positions"]]).

    Returns
    -------
    dict | None
        {
            "array": numpy.ndarray,
            "matched_key": str,
            "pattern": list[str],
            "shape": tuple
        }
        Returns None if no matching array is found.
    """
    normalized_patterns = [
        [token.lower() for token in pattern if token]
        for pattern in key_token_patterns
        if pattern
    ]

    best = None

    def _tokenize(path):
        return [token for token in re.split(r"[^a-z0-9]+", path.lower()) if token]

    def _consider(path, value):
        nonlocal best

        try:
            array = tensor_to_numpy(value)
        except Exception:
            return

        if not isinstance(array, np.ndarray):
            return

        path_tokens = _tokenize(path)
        if not path_tokens:
            return

        path_token_set = set(path_tokens)

        for pattern in normalized_patterns:
            if all(token in path_token_set for token in pattern):
                # Higher score means a more specific and tighter key match.
                score = len(pattern) * 100 - len(path_tokens)
                if best is None or score > best["score"]:
                    best = {
                        "array": array,
                        "matched_key": path,
                        "pattern": pattern,
                        "shape": tuple(array.shape),
                        "score": score,
                    }

    def _walk(obj, path_prefix=""):
        if isinstance(obj, dict):
            for key, value in obj.items():
                path = f"{path_prefix}/{key}" if path_prefix else str(key)
                _consider(path, value)
                _walk(value, path)
        elif isinstance(obj, (list, tuple)):
            for idx, value in enumerate(obj):
                path = f"{path_prefix}/{idx}" if path_prefix else str(idx)
                _consider(path, value)
                _walk(value, path)

    _walk(container)

    if best is None:
        return None

    best.pop("score", None)
    return best


def ingest_output_pkl(archive_path, pkl_file, overwrite=False):
    """
    Load a VizFold/OpenFold output .pkl and route known arrays into the archive.

    Current routing behavior:
    - final_atom_positions (N, 37, 3) -> structure/coordinates using CA atom (index 1)
    - residue_types/aatype (if found) -> structure/residue_types
    - pair representation (if found) -> representations/pair

    Safety and traceability behavior:
    - Uses token-pattern key matching instead of broad substring checks.
    - Returns key-level traceability in summary["key_matches"].
    """
    with open(pkl_file, "rb") as f:
        output_dict = pickle.load(f)

    if not isinstance(output_dict, dict):
        raise ValueError("Expected pickle file to contain a dictionary output")

    summary = {
        "source_file": pkl_file,
        "stored": [],
        "skipped": [],
        "key_matches": {},
    }

    final_positions_match = _extract_best_matching_array(
        output_dict,
        [["final", "atom", "positions"], ["final", "positions"]],
    )
    residue_types_match = _extract_best_matching_array(
        output_dict,
        [["aatype"], ["residue", "type"]],
    )
    pair_match = _extract_best_matching_array(
        output_dict,
        [["pair", "representation"], ["pair", "activations"], ["pair"]],
    )

    summary["key_matches"]["final_positions"] = {
        "pattern": ["final", "atom", "positions"],
        "matched_key": None if final_positions_match is None else final_positions_match["matched_key"],
        "shape": None if final_positions_match is None else final_positions_match["shape"],
    }
    summary["key_matches"]["residue_types"] = {
        "pattern": ["aatype"],
        "matched_key": None if residue_types_match is None else residue_types_match["matched_key"],
        "shape": None if residue_types_match is None else residue_types_match["shape"],
    }
    summary["key_matches"]["pair_representation"] = {
        "pattern": ["pair"],
        "matched_key": None if pair_match is None else pair_match["matched_key"],
        "shape": None if pair_match is None else pair_match["shape"],
    }

    final_positions = None if final_positions_match is None else final_positions_match["array"]
    residue_types = None if residue_types_match is None else residue_types_match["array"]

    if final_positions is not None:
        if final_positions.ndim == 3 and final_positions.shape[-1] == 3:
            coords = final_positions[:, 1, :] if final_positions.shape[1] > 1 else final_positions[:, 0, :]
            store_structure_coordinates(
                archive_path,
                coords,
                residue_types=residue_types,
                overwrite=overwrite,
            )
            summary["stored"].append("structure/coordinates")
            if residue_types is not None:
                summary["stored"].append("structure/residue_types")
        else:
            summary["skipped"].append("final_atom_positions (unexpected shape)")
    else:
        summary["skipped"].append("final_atom_positions (not found)")

    pair_array = None if pair_match is None else pair_match["array"]
    if pair_array is not None and isinstance(pair_array, np.ndarray):
        if pair_array.ndim == 3 and pair_array.shape[0] == pair_array.shape[1]:
            store_pair_representation(archive_path, pair_array, overwrite=overwrite)
            summary["stored"].append("representations/pair")
        else:
            summary["skipped"].append("representations/pair (unexpected shape)")
    else:
        summary["skipped"].append("representations/pair (not found)")

    return summary


