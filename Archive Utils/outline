def store_structure_coordinates(path, coordinates, residue_types=None, overwrite=False):
    """
    Store predicted protein structure coordinates.

    These coordinates represent the predicted 3D structure of
    a protein sequence.

    Expected coordinate shape:
        (num_residues, 3)

    Archive layout:
        structure/coordinates
        structure/residue_types (optional)

    Responsibilities:
    -----------------
    - Validate coordinate dimensions
    - Create structure group
    - Store coordinate array
    - Optionally store residue type information

    Parameters
    ----------
    path : str
        Root path to the Zarr archive.

    coordinates : numpy.ndarray
        Array of atomic coordinates.

    residue_types : optional array-like
        Residue identity information.

    overwrite : bool, optional
        Whether to overwrite existing structure datasets. Default is False.

    Returns
    -------
    None
    """
    coordinates = tensor_to_numpy(coordinates)

    # Validate coordinate dimensions: (num_residues, 3)
    if coordinates.ndim != 2:
        raise ValueError(
            f"Expected 2D coordinate array (num_residues, 3), "
            f"got {coordinates.ndim}D with shape {coordinates.shape}"
        )
    if coordinates.shape[-1] != 3:
        raise ValueError(
            f"Expected last dimension to be 3 (x, y, z), "
            f"got {coordinates.shape[-1]}"
        )

    num_residues = coordinates.shape[0]
    archive_path = path.rstrip("/")

    # Use method 2 for in-archive storage
    tensor_to_zarr_array(
        f"{archive_path}::structure/coordinates",
        coordinates,
        overwrite=overwrite,
    )

    # Optionally store residue type information
    if residue_types is not None:
        residue_types = tensor_to_numpy(residue_types)
        residue_types = np.squeeze(residue_types)  # handle (1, N) from batched aatype
        if len(residue_types) != num_residues:
            raise ValueError(
                f"residue_types length ({len(residue_types)}) must match "
                f"number of residues ({num_residues})"
            )
        tensor_to_zarr_array(
            f"{archive_path}::structure/residue_types",
            residue_types,
            overwrite=overwrite,
        )


